:80 {
	encode zstd gzip

	handle /api/* {
		reverse_proxy app:3001
	}

	handle /uploads/* {
		reverse_proxy app:3001
	}

	@assets path /assets/*
	handle @assets {
		root * /srv
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		root * /srv
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
